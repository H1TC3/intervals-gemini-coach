name: Synchronizacja Danych
on:
  schedule:
    - cron: '15 5 * * *'
  workflow_dispatch:

jobs:
  sync:
    runs-on: ubuntu-latest
    permissions:
      contents: write
    steps:
      - uses: actions/checkout@v4
      - run: |
          python -m pip install requests
          python coach.py
          git config --global user.name "Bot"
          git config --global user.email "bot@bot.com"
          git add dane/dzisiaj.json
          git commit -m "Aktualizacja danych" || exit 0
          git push
